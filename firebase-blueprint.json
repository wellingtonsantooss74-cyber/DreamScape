{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Informações de perfil do usuário e preferências de tema.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "ID único do usuário no Firebase Auth." },
        "displayName": { "type": "string", "description": "Nome de exibição do usuário." },
        "email": { "type": "string", "description": "E-mail do usuário." },
        "photoURL": { "type": "string", "description": "URL da foto de perfil do usuário." },
        "theme": { "type": "string", "enum": ["light", "dark", "sepia", "ocean"], "description": "Tema preferido do app." },
        "color": { "type": "string", "enum": ["purple", "blue", "green", "rose", "orange"], "description": "Cor de destaque preferida." },
        "navColor": { "type": "string", "enum": ["default", "glass", "primary", "dark", "colorful"], "description": "Cor da barra de navegação." },
        "isPremium": { "type": "boolean", "description": "Status da assinatura premium." },
        "childrenProfiles": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "age": { "type": "number" },
              "interests": { "type": "array", "items": { "type": "string" } }
            }
          },
          "description": "Perfis das crianças vinculadas à conta."
        },
        "parentPin": { "type": "string", "description": "PIN de 4 dígitos para acesso dos pais." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Data da última atualização." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Story": {
      "title": "Story",
      "description": "Uma história mágica gerada para uma criança.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string", "description": "ID do usuário dono da história." },
        "createdAt": { "type": "string", "format": "date-time" },
        "titulo": { "type": "string" },
        "idade_alvo": { "type": "string" },
        "personagens_principais": { "type": "array", "items": { "type": "object" } },
        "paginas": { "type": "array", "items": { "type": "object" } },
        "interatividade": { "type": "object" }
      },
      "required": ["id", "uid", "createdAt", "titulo", "paginas"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Documento de perfil do usuário."
    },
    "/stories/{storyId}": {
      "schema": "Story",
      "description": "Coleção de histórias mágicas."
    }
  }
}
